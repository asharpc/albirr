# --- Django ---
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=albirr.idrp.org.in,localhost,127.0.0.1,backend

# Comma-separated list of EXACT origins allowed to call the API from the browser.
# Must include the scheme (https://) and any subdomain that hosts the FE.
CORS_ALLOWED_ORIGINS=https://albirr.idrp.org.in,https://albirr.pages.dev,http://localhost:5173,http://localhost:8080
# Comma-separated regex patterns for origins. Use this for wildcard subdomains
# (e.g. every Cloudflare Pages preview deploy gets <hash>.albirr.pages.dev).
CORS_ALLOWED_ORIGIN_REGEXES=^https://[a-z0-9-]+\.albirr\.pages\.dev$
# Set to True to bypass the allow-list (dev only).
CORS_ALLOW_ALL_ORIGINS=False
# Required by Django ≥4 for cross-origin POST/PUT/DELETE (CSRF). Use scheme + host, no path.
# Supports wildcards: https://*.albirr.pages.dev
CSRF_TRUSTED_ORIGINS=https://albirr.idrp.org.in,https://albirr.pages.dev,https://*.albirr.pages.dev

# --- Database ---
# DB_ENGINE: "postgres" (default) or "sqlite"
DB_ENGINE=postgres
DB_NAME=albirr
DB_USER=albirr
DB_PASSWORD=albirr

# Default: DB_HOST=db points at the postgres container (started by default).
# To use an external DB (RDS, managed postgres, etc.):
#   1. Set DB_HOST to the external host below
#   2. Start without the db service:  docker compose up -d --build backend frontend
DB_HOST=db
DB_PORT=5432

# Host port exposed for the postgres container
DB_PORT_HOST=5432

# --- Ports ---
BACKEND_PORT=9001
FRONTEND_PORT=8080

# --- Default superuser ---
# Auto-created (or password-reset) on every backend startup.
# Leave EMAIL or PASSWORD blank to skip auto-creation.
DJANGO_SUPERUSER_EMAIL=admin@albirr.local
DJANGO_SUPERUSER_PASSWORD=change-me
DJANGO_SUPERUSER_FIRST_NAME=Admin
DJANGO_SUPERUSER_LAST_NAME=User

# --- Frontend build ---
# Baked into the Vite bundle at build time; rebuild the frontend image
# if you change this. For the full-stack compose, leave it relative
# (/api/v1/) so nginx can proxy it.
VITE_API_BASE_URL=/api/v1/

# --- Caddy (docker-compose.backend.yml only) ---
# Set CADDY_HOSTNAME to a real domain for automatic HTTPS via Let's Encrypt.
# Leave unset (default ":80") to serve plain HTTP on port 80 only.
# Examples:
#   CADDY_HOSTNAME=api.albirr.example.com   # auto TLS, :80 -> :443 redirect
#   CADDY_HOSTNAME=:80                       # HTTP only (default)
#CADDY_HOSTNAME=api.albirr.example.com
#ACME_EMAIL=you@example.com
